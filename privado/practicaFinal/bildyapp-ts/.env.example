# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/bildyapp

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary (subida de firmas, PDFs y logos) ───────────────────────────────
# Regístrate en https://cloudinary.com (plan gratuito disponible)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Mailtrap (email en desarrollo) ───────────────────────────────────────────
# Regístrate en https://mailtrap.io → Email Testing → SMTP Settings
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=tu_mailtrap_user
MAIL_PASS=tu_mailtrap_password
MAIL_FROM=noreply@bildyapp.com

# ── Slack (logging de errores 5XX) ────────────────────────────────────────────
# Crea un Incoming Webhook en https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TU/WEBHOOK/URL

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
